{
    "swagger": "2.0",
    "info": {
        "description": "API documentation",
        "title": "Swagger",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://aban.io/support",
            "email": "info@aban.io"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "paths": {
        "/apis/admin/lots": {
            "get": {
                "description": "House/admin lot listing, optionally filtered by ?state=DRAFT|CERTIFIED|SCHEDULED|REJECTED and ?week=YYYY-Www.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog-admin"
                ],
                "summary": "Admin lot list",
                "parameters": [
                    {
                        "type": "string",
                        "description": "State filter",
                        "name": "state",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "ISO week filter",
                        "name": "week",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/dto.LotResp"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad filter",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apis/admin/lots/{id}/attest": {
            "post": {
                "description": "House/inspector records an attestation. A PASS seal unlocks certification (the gate). A FAIL on a DRAFT lot rejects it. Emits attestation.recorded.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog-admin"
                ],
                "summary": "Attest a lot",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lot UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Attestation",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.AttestRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/dto.AttestationResp"
                        }
                    },
                    "400": {
                        "description": "Bad request / invalid state",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Lot not found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apis/admin/lots/{id}/certify": {
            "post": {
                "description": "House certifies a DRAFT lot. The certification gate requires an existing PASS attestation; without one this returns RESOURCE_INVALID. Emits lot.certified.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog-admin"
                ],
                "summary": "Certify a lot",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lot UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.LotResp"
                        }
                    },
                    "400": {
                        "description": "No PASS attestation / illegal transition",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Lot not found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apis/admin/lots/{id}/schedule": {
            "post": {
                "description": "House schedules a CERTIFIED lot into its ISO week's gallery. Enforces the weekly 32-lot supply cap; exceeding it returns RESOURCE_INVALID. Emits lot.scheduled with atype + params.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog-admin"
                ],
                "summary": "Schedule a lot",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lot UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Optional scheduledAt (ISO-8601 UTC)",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/dto.ScheduleRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.LotResp"
                        }
                    },
                    "400": {
                        "description": "Weekly cap reached / not certified",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Lot not found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apis/gallery/weekly": {
            "get": {
                "description": "This ISO week's SCHEDULED lots (public, no auth). Pass ?week=YYYY-Www to read a specific week; defaults to the current ISO week. Returns the 32-lot supply cap so the client can render \"n of 32\".",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog"
                ],
                "summary": "Weekly gallery",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ISO week, e.g. 2026-W23 (defaults to current)",
                        "name": "week",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.WeeklyResp"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apis/lots/{id}": {
            "get": {
                "description": "Public lot detail: atype, params, state, and the attestation summary (the certification gate's evidence).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "catalog"
                ],
                "summary": "Lot detail",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lot UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.LotDetailResp"
                        }
                    },
                    "400": {
                        "description": "Bad UUID",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/healthz/liveness": {
            "get": {
                "description": "Check the liveness of the service",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "healthz"
                ],
                "summary": "Healthz Liveness",
                "operationId": "healthz-liveness",
                "responses": {
                    "200": {
                        "description": "ok"
                    }
                }
            }
        },
        "/healthz/panic": {
            "get": {
                "tags": [
                    "healthz"
                ],
                "summary": "Panic for test",
                "responses": {
                    "500": {
                        "description": "panic",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/healthz/rediness": {
            "get": {
                "description": "Check the readiness of the service",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "healthz"
                ],
                "summary": "Healthz Readiness",
                "operationId": "healthz-rediness",
                "responses": {
                    "200": {
                        "description": "ok"
                    }
                }
            }
        },
        "/healthz/sleep/{time}": {
            "get": {
                "tags": [
                    "healthz"
                ],
                "summary": "Long Run for test",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Time to sleep, e.g. 30s",
                        "name": "time",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "ok"
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.AttestRequest": {
            "type": "object",
            "required": [
                "inspectorId",
                "result"
            ],
            "properties": {
                "inspectorId": {
                    "type": "string"
                },
                "notesRef": {
                    "type": "string",
                    "maxLength": 512
                },
                "result": {
                    "type": "string",
                    "enum": [
                        "PASS",
                        "FAIL"
                    ]
                }
            }
        },
        "dto.AttestationResp": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "inspectorId": {
                    "type": "string"
                },
                "lotId": {
                    "type": "string"
                },
                "notesRef": {
                    "type": "string"
                },
                "recordedAt": {
                    "type": "string"
                },
                "result": {
                    "description": "PASS | FAIL",
                    "type": "string"
                }
            }
        },
        "dto.ErrorResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "dto.LotDetailResp": {
            "type": "object",
            "properties": {
                "attestations": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.AttestationResp"
                    }
                },
                "certified": {
                    "description": "has at least one PASS attestation",
                    "type": "boolean"
                },
                "lot": {
                    "$ref": "#/definitions/dto.LotResp"
                }
            }
        },
        "dto.LotResp": {
            "type": "object",
            "properties": {
                "appraisedValueCents": {
                    "type": "integer"
                },
                "atype": {
                    "description": "DUTCH | VICKREY | UNIQBID",
                    "type": "string"
                },
                "createdAt": {
                    "description": "ISO-8601 UTC",
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "durationDays": {
                    "description": "null for DUTCH",
                    "type": "integer"
                },
                "id": {
                    "type": "string"
                },
                "isoWeek": {
                    "description": "e.g. \"2026-W23\"",
                    "type": "string"
                },
                "objectId": {
                    "type": "string"
                },
                "reserveCents": {
                    "type": "integer"
                },
                "scheduledAt": {
                    "type": "string"
                },
                "sellerAccountId": {
                    "type": "string"
                },
                "state": {
                    "description": "DRAFT | CERTIFIED | SCHEDULED | REJECTED",
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "dto.ScheduleRequest": {
            "type": "object",
            "properties": {
                "scheduledAt": {
                    "description": "ISO-8601 UTC; defaults to now",
                    "type": "string"
                }
            }
        },
        "dto.WeeklyResp": {
            "type": "object",
            "properties": {
                "lots": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.LotResp"
                    }
                },
                "supplyCap": {
                    "description": "32",
                    "type": "integer"
                },
                "week": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BasicAuth": {
            "type": "basic"
        }
    },
    "externalDocs": {
        "description": "OpenAPI",
        "url": "https://swagger.io/resources/open-api/"
    }
}