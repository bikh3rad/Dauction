# Dauction frontend environment.
# Copy to .env.local and adjust as needed.

# Base path for all API calls. In dev this is a same-origin path that Vite proxies
# to the gateway (see vite.config.ts). In production point it at the real gateway,
# e.g. https://app.dauction.xyz/apis
VITE_API_BASE=/apis

# Where the Vite dev proxy forwards /apis (the gateway edge).
VITE_GATEWAY_PROXY=http://localhost:18080

# Force the schema-accurate mock layer instead of calling the backend.
#   1 / true  → always use mocks (offline / design work)
#   0 / unset → call the API, fall back to mocks only when a request fails
VITE_USE_MOCK=0

# Dev auth: the gateway's dev scheme treats the Bearer token AS the account UUID.
# This seeds a signed-in member so participation-gated screens work without a login backend.
VITE_DEV_ACCOUNT_ID=0a7a4e00-0000-4000-8000-00000000a74e
