# Proxy settings for OFFLINE hosts (no direct internet, only a local HTTP/HTTPS
# proxy). Used together with docker-compose.proxy.yml.
#
# Setup on the offline host:
#   cd deploy
#   cp .env.proxy.example .env
#   docker compose up -d --build      # COMPOSE_FILE below pulls in both files
#
# Do NOT copy this to .env on internet-connected hosts — they build direct.

# Auto-select base + proxy override so you can just run `docker compose ...`.
COMPOSE_FILE=docker-compose.yml:docker-compose.proxy.yml

# Your local proxy (matches the default baked into docker-compose.proxy.yml).
BUILD_HTTP_PROXY=http://127.0.0.1:10880
BUILD_HTTPS_PROXY=http://127.0.0.1:10880
BUILD_NO_PROXY=localhost,127.0.0.1
